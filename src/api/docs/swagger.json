{
  "openapi": "3.0.0",
  "info": {
    "title": "Sample API",
    "description": "A brief description of what the API does.",
    "version": "1.0.1"
  },
  "paths": {
    "/users": {
      "get": {
        "summary": "Returns a list of users.",
        "responses": {
          "200": {
            "description": "A JSON array of user names.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/User" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" }
        }
      }
    }
  }
}