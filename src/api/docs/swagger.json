    "/borrow": {
      "get": {
        "summary": "List all borrows",
        "tags": ["Borrows"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search term to filter borrows.",
            "schema": { "type": "string" }
          },
          {
            "name": "borrowerId",
            "in": "query",
            "description": "ID of the borrower (student or professor).",
            "schema": { "type": "integer" }
          },
          {
            "name": "borrowerType",
            "in": "query",
            "description": "Type of borrower.",
            "schema": { "type": "string", "enum": ["student", "professor"] }
          },
          {
            "name": "startPeriod",
            "in": "query",
            "description": "Filter borrows starting from this date (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "endPeriod",
            "in": "query",
            "description": "Filter borrows up to this date (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          }
        ],
        "responses": {
          "200": {
            "description": "Borrows retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponseSuccess" },
                    {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "example": "BORROWS_LIST" },
                        "data": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/BorrowFull" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "summary": "Create a borrow",
        "tags": ["Borrows"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
