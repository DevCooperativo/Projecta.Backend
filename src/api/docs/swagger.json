{
  "openapi": "3.0.0",
  "info": {
    "title": "Projecta API",
    "description": "API documentation for the Projecta backend.",
    "version": "1.0.1"
  },
  "paths": {
    "/auth/signin": {
      "post": {
        "summary": "Sign in",
        "description": "Authenticates a user and sets an `auth_cookie` (HttpOnly) containing the JWT.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SigninRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sign in successful.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponseSuccess" },
                    {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "example": "SIGN_IN_SUCCESS" },
                        "data": { "$ref": "#/components/schemas/SigninData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid fields.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponseWarn" },
                    {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "example": "VALIDATION_ERROR" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Invalid email, password, or profile type.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponseInfo" },
                    {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "example": "NOT_FOUND" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponseError" },
                    {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "example": "INTERNAL_SERVER_ERROR" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

